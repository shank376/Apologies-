<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💌 Emergency Forgiveness System</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #ffb3c6;
    --blush: #ffd6e0;
    --cream: #fff8f0;
    --lavender: #e8d5f5;
    --lilac: #c9b1e8;
    --sky: #d4eeff;
    --mint: #c8f0e0;
    --text: #5a3e5e;
    --soft: #9b7daa;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
    overflow: hidden;
    position: relative;
  }

  /* FLOATING BACKGROUND DOODLES */
  .bg-doodle {
    position: fixed;
    pointer-events: none;
    font-size: 1.5rem;
    animation: floatAround linear infinite;
    opacity: 0.15;
    z-index: 0;
  }

  @keyframes floatAround {
    0% { transform: translateY(100vh) rotate(0deg); }
    100% { transform: translateY(-20vh) rotate(360deg); }
  }

  /* PAGES */
  .page {
    display: none;
    position: fixed;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    z-index: 1;
    animation: pageIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .page.active { display: flex; }

  @keyframes pageIn {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* CARD STYLE */
  .card {
    background: white;
    border-radius: 28px;
    padding: 2.5rem 3rem;
    max-width: 520px;
    width: 100%;
    box-shadow: 0 8px 40px rgba(180, 130, 200, 0.2), 0 2px 8px rgba(0,0,0,0.06);
    border: 2px solid rgba(255, 179, 198, 0.3);
    position: relative;
    text-align: center;
    background-image: 
      radial-gradient(circle at 90% 10%, rgba(232, 213, 245, 0.4) 0%, transparent 50%),
      radial-gradient(circle at 10% 90%, rgba(255, 214, 224, 0.4) 0%, transparent 50%);
  }

  /* PAPER TEXTURE LINES */
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 28px;
    background-image: repeating-linear-gradient(
      transparent, transparent 27px,
      rgba(200, 170, 220, 0.08) 27px, rgba(200, 170, 220, 0.08) 28px
    );
    pointer-events: none;
  }

  /* TYPOGRAPHY */
  h1 {
    font-family: 'Caveat', cursive;
    font-size: 2.8rem;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Caveat', cursive;
    font-size: 2.2rem;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.8rem;
  }

  p {
    font-size: 1.05rem;
    color: var(--soft);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .big-text {
    font-family: 'Caveat', cursive;
    font-size: 1.6rem;
    color: var(--text);
    line-height: 1.5;
  }

  /* BUTTONS */
  .btn-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.8rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Caveat', cursive;
    font-size: 1.3rem;
    font-weight: 700;
    padding: 0.7rem 2rem;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    letter-spacing: 0.02em;
  }

  .btn:hover { transform: scale(1.08) translateY(-2px); }
  .btn:active { transform: scale(0.96); }

  .btn-yes {
    background: linear-gradient(135deg, var(--pink), var(--lilac));
    color: white;
    box-shadow: 0 4px 16px rgba(255, 100, 150, 0.3);
  }

  .btn-no {
    background: white;
    color: var(--soft);
    border: 2px solid var(--blush);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .btn-maybe {
    background: linear-gradient(135deg, var(--lavender), var(--sky));
    color: var(--text);
    box-shadow: 0 4px 16px rgba(180, 130, 220, 0.25);
  }

  /* DOODLE EMOJIS ON CARD */
  .doodle-corner {
    position: absolute;
    font-size: 1.8rem;
    opacity: 0.6;
  }
  .doodle-tl { top: -10px; left: -10px; transform: rotate(-20deg); }
  .doodle-tr { top: -10px; right: -10px; transform: rotate(20deg); }
  .doodle-bl { bottom: -10px; left: -10px; transform: rotate(15deg); }
  .doodle-br { bottom: -10px; right: -10px; transform: rotate(-15deg); }

  /* LOADING PAGE */
  #page-loading .status-text {
    font-family: 'Caveat', cursive;
    font-size: 1.1rem;
    color: var(--soft);
    margin-top: 1rem;
    min-height: 1.5em;
  }

  .loading-bar-wrap {
    width: 200px;
    height: 8px;
    background: var(--blush);
    border-radius: 10px;
    margin: 1.2rem auto 0;
    overflow: hidden;
  }

  .loading-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--pink), var(--lilac));
    border-radius: 10px;
    width: 0%;
    transition: width 0.4s ease;
  }

  .big-emoji { font-size: 4rem; margin-bottom: 0.5rem; display: block; }

  /* POPUP */
  .popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(90, 62, 94, 0.15);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease both;
  }

  .popup-overlay.active { display: flex; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .popup-box {
    background: white;
    border-radius: 24px;
    padding: 2rem 2.5rem;
    text-align: center;
    max-width: 360px;
    width: 90%;
    box-shadow: 0 16px 60px rgba(180, 130, 200, 0.35);
    border: 2px solid var(--blush);
    animation: bounceIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes bounceIn {
    from { transform: scale(0.7); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* SHAKE ANIMATION */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    15% { transform: translateX(-8px) rotate(-1deg); }
    30% { transform: translateX(8px) rotate(1deg); }
    45% { transform: translateX(-6px); }
    60% { transform: translateX(6px); }
    75% { transform: translateX(-4px); }
    90% { transform: translateX(4px); }
  }

  .shake { animation: shake 0.6s ease both; }

  /* ANGER METER */
  .meter-wrap {
    background: var(--blush);
    border-radius: 16px;
    padding: 1.2rem;
    margin: 1rem 0;
  }

  .meter-emojis {
    font-size: 1.8rem;
    letter-spacing: 0.2rem;
    transition: all 0.4s ease;
  }

  /* MINI GAME */
  #game-canvas {
    border-radius: 16px;
    background: linear-gradient(135deg, var(--sky), var(--lavender));
    cursor: crosshair;
    display: block;
    margin: 0 auto;
    border: 2px solid rgba(180, 130, 220, 0.3);
  }

  /* LETTER */
  .letter-envelope {
    font-size: 5rem;
    display: block;
    cursor: pointer;
    transition: transform 0.3s ease;
    animation: wobble 2s ease-in-out infinite;
  }

  @keyframes wobble {
    0%, 100% { transform: rotate(-3deg) scale(1); }
    50% { transform: rotate(3deg) scale(1.05); }
  }

  .letter-content {
    display: none;
    background: linear-gradient(135deg, #fff9f0, #fff0f5);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 1rem 0;
    font-family: 'Caveat', cursive;
    font-size: 1.2rem;
    color: var(--text);
    line-height: 1.8;
    border: 1px dashed var(--pink);
    text-align: left;
    animation: pageIn 0.4s ease both;
  }

  /* POLAROID */
  .polaroid-grid {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 1rem 0;
  }

  .polaroid {
    background: white;
    padding: 0.7rem 0.7rem 2rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    transform: rotate(var(--rot));
    border: 1px solid #eee;
    width: 120px;
    transition: transform 0.3s ease;
    cursor: default;
  }

  .polaroid:hover { transform: rotate(0deg) scale(1.08); z-index: 10; }

  .polaroid .pol-emoji { font-size: 2.5rem; text-align: center; padding: 0.5rem 0; display: block; }
  .polaroid .pol-caption { font-family: 'Caveat', cursive; font-size: 0.85rem; color: var(--soft); text-align: center; line-height: 1.3; }

  /* RAIN ANIMATION */
  .rain-drop {
    position: fixed;
    width: 2px;
    background: linear-gradient(transparent, var(--sky));
    animation: rain linear infinite;
    z-index: 0;
    pointer-events: none;
    border-radius: 2px;
  }

  @keyframes rain {
    from { transform: translateY(-20px); opacity: 0.8; }
    to { transform: translateY(110vh); opacity: 0; }
  }

  /* STARS PAGE */
  .floating-star {
    position: fixed;
    pointer-events: none;
    animation: starFloat ease-in-out infinite;
    z-index: 0;
  }

  @keyframes starFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    50% { transform: translateY(-20px) rotate(180deg); opacity: 1; }
  }

  /* FINAL PAGE */
  .confetti-piece {
    position: fixed;
    width: 10px;
    height: 10px;
    animation: confettiFall linear forwards;
    border-radius: 2px;
    z-index: 0;
    pointer-events: none;
  }

  @keyframes confettiFall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  /* HEART HEAL */
  .heart-broken { font-size: 3.5rem; display: block; animation: pulse 1.5s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.1); } }

  /* FLOATING STATUS MESSAGES */
  #status-float {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Caveat', cursive;
    font-size: 1rem;
    color: var(--soft);
    background: white;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 50;
    white-space: nowrap;
    border: 1px solid var(--blush);
  }

  /* NO BUTTON RUNNING */
  #running-no {
    position: fixed;
    font-family: 'Caveat', cursive;
    font-size: 1.3rem;
    font-weight: 700;
    background: white;
    color: var(--soft);
    border: 2px solid var(--blush);
    padding: 0.7rem 2rem;
    border-radius: 50px;
    cursor: pointer;
    transition: none;
    z-index: 200;
    display: none;
  }

  /* PROGRESS DOTS */
  .progress-dots {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .progress-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--blush);
    transition: all 0.3s ease;
  }

  .progress-dots span.done {
    background: linear-gradient(135deg, var(--pink), var(--lilac));
    transform: scale(1.2);
  }

  /* TYPEWRITER */
  .typewriter { border-right: 2px solid var(--pink); animation: blink 0.8s step-end infinite; }
  @keyframes blink { 0%,100% { border-color: var(--pink); } 50% { border-color: transparent; } }

  /* RESPONSIVE */
  @media (max-width: 500px) {
    .card { padding: 2rem 1.5rem; }
    h1 { font-size: 2.2rem; }
    h2 { font-size: 1.8rem; }
  }
</style>
</head>
<body>

<!-- Floating BG doodles -->
<div id="bg-doodles"></div>

<!-- Status float -->
<div id="status-float"></div>

<!-- Running NO button -->
<button id="running-no" onclick="catchRunningNo()">no</button>

<!-- POPUPS -->
<div class="popup-overlay" id="popup-ouch">
  <div class="popup-box">
    <div style="font-size:3rem; margin-bottom:0.5rem">😔</div>
    <h2 style="font-size:1.6rem">that hurt a little ngl</h2>
    <p style="margin-top:0.5rem">but okay. i see how it is.</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="closePopup('popup-ouch'); nextPage()">continue anyway 😭</button>
    </div>
  </div>
</div>

<div class="popup-overlay" id="popup-error">
  <div class="popup-box" id="popup-error-box">
    <div style="font-size:2.5rem; margin-bottom:0.5rem">💻</div>
    <p style="font-family:'Caveat',cursive; font-size:1.4rem; color:var(--text)">ERROR: incorrect answer detected.</p>
    <p id="error-loading-text" style="margin-top:0.5rem; color:var(--soft); font-size:0.95rem">Rechecking emotional database…</p>
    <div class="loading-bar-wrap" style="margin-top:0.8rem">
      <div class="loading-bar-fill" id="error-bar"></div>
    </div>
    <p id="error-result" style="display:none; font-family:'Caveat',cursive; font-size:1.3rem; color:var(--text); margin-top:1rem">Result: he definitely regrets it. 💯</p>
    <div class="btn-row" id="error-btns" style="display:none">
      <button class="btn btn-maybe" onclick="closePopup('popup-error'); nextPage()">okay maybe 😭</button>
      <button class="btn btn-no" onclick="closePopup('popup-error')">still no</button>
    </div>
  </div>
</div>

<div class="popup-overlay" id="popup-bro">
  <div class="popup-box">
    <div style="font-size:3.5rem; margin-bottom:0.5rem">🐈</div>
    <p style="font-family:'Caveat',cursive; font-size:1.4rem; color:var(--text)">"bro is trying his best."</p>
    <p style="margin-top:0.5rem; color:var(--soft)">please reconsider 🥺</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="closePopup('popup-bro'); nextPage()">fine 😤</button>
      <button class="btn btn-no" onclick="closePopup('popup-bro')">no</button>
    </div>
  </div>
</div>

<div class="popup-overlay" id="popup-resigned">
  <div class="popup-box">
    <div style="font-size:3.5rem; margin-bottom:0.5rem">⚠️</div>
    <p style="font-family:'Caveat',cursive; font-size:1.4rem; color:var(--text)">No button has resigned from its job.</p>
    <p style="margin-top:0.5rem; color:var(--soft); font-size:0.9rem">Reason: too much emotional pressure.</p>
    <p style="margin-top:0.8rem; color:var(--soft); font-size:0.85rem">Only YES remains now.</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="closePopup('popup-resigned'); goFinal()">yes 🤍</button>
    </div>
  </div>
</div>

<div class="popup-overlay" id="popup-rain">
  <div class="popup-box">
    <div id="rain-text" style="font-family:'Caveat',cursive; font-size:1.4rem; color:var(--text)">the developer of this website is crying. 😭</div>
    <div class="btn-row" id="rain-btn" style="display:none">
      <button class="btn btn-maybe" onclick="closePopup('popup-rain'); nextPage()">okay fine 🙄</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 1: LOADING ============ -->
<div class="page active" id="page-loading">
  <div class="card">
    <span style="font-size:1.2rem; letter-spacing:0.1em; color:var(--soft); font-weight:600; display:block; margin-bottom:1rem">💌 EMERGENCY FORGIVENESS SYSTEM v2.0</span>
    <span class="big-emoji" id="loading-emoji">☁️</span>
    <div class="loading-bar-wrap">
      <div class="loading-bar-fill" id="main-loading-bar"></div>
    </div>
    <p class="status-text" id="loading-status">initializing puppy eyes…</p>
    <div class="btn-row" id="enter-btn-wrap" style="display:none">
      <button class="btn btn-yes" onclick="goTo(2)">[ Enter ] 💌</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 2: HI ============ -->
<div class="page" id="page-2">
  <div class="progress-dots" id="dots-2"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">🌸</span>
    <span class="doodle-corner doodle-tr">✨</span>
    <span class="doodle-corner doodle-bl">🌷</span>
    <span class="doodle-corner doodle-br">💫</span>
    <h1 id="hi-text" style="font-size:3.5rem">Hi…</h1>
    <p id="hi-sub" style="opacity:0; transition:opacity 0.6s ease; font-size:1.15rem">Can I try to make things right?</p>
    <div class="btn-row" id="hi-btns" style="opacity:0; transition:opacity 0.5s ease; pointer-events:none">
      <button class="btn btn-yes" onclick="nextPage()">yes 🥺</button>
      <button class="btn btn-no" onclick="showPopup('popup-ouch')">no</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 3: I ACTED STUPID ============ -->
<div class="page" id="page-3">
  <div class="progress-dots" id="dots-3"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">📓</span>
    <span class="doodle-corner doodle-tr">✏️</span>
    <div style="font-size:2.5rem; margin-bottom:0.8rem">📖</div>
    <h2>First of all…</h2>
    <p class="big-text">I know I acted stupid.</p>
    <p style="font-size:0.9rem; margin-top:0.5rem; color:var(--soft)">Would you say this is…</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="nextPage()">true ✓</button>
      <button class="btn btn-maybe" onclick="nextPage()">VERY true ✓✓</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 4: DO I REGRET IT ============ -->
<div class="page" id="page-4">
  <div class="progress-dots" id="dots-4"></div>
  <div class="card" id="page4-card">
    <span class="doodle-corner doodle-tl">🤔</span>
    <span class="doodle-corner doodle-tr">💭</span>
    <div style="font-size:2.5rem; margin-bottom:0.8rem">🔍</div>
    <h2>But do you think I regret it?</h2>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="nextPage()">yes obviously</button>
      <button class="btn btn-no" onclick="triggerError()">no</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 5: ANGER METER ============ -->
<div class="page" id="page-5">
  <div class="progress-dots" id="dots-5"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">📊</span>
    <span class="doodle-corner doodle-tr">🌡️</span>
    <div style="font-size:2.5rem; margin-bottom:0.5rem">📈</div>
    <h2>Current anger level analysis.</h2>
    <div class="meter-wrap">
      <div class="meter-emojis" id="anger-emojis">🔥🔥🔥🔥🔥</div>
      <p id="anger-label" style="font-family:'Caveat',cursive; font-size:1.1rem; margin-top:0.5rem">CRITICAL LEVEL</p>
    </div>
    <p style="font-size:0.9rem; color:var(--soft)">tap to reduce 👇</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="reduceAnger('maximum')">maximum 💀</button>
      <button class="btn btn-maybe" onclick="reduceAnger('dangerous')">dangerous 😤</button>
      <button class="btn btn-no" onclick="reduceAnger('catastrophic')">catastrophic ☠️</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 6: LETTER ============ -->
<div class="page" id="page-6">
  <div class="progress-dots" id="dots-6"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">💌</span>
    <span class="doodle-corner doodle-tr">📬</span>
    <span id="envelope-icon" class="letter-envelope" onclick="openLetter()">💌</span>
    <p id="envelope-hint" style="font-size:0.9rem; color:var(--soft)">tap to open</p>
    <div class="letter-content" id="letter-content">
      <p>Hey.</p><br>
      <p>I know I messed up. And I know saying "sorry" is easy — actually meaning it is the harder part.</p><br>
      <p>I genuinely didn't want things to go the way they did. You matter to me, and seeing you upset because of something I did… that stays with me.</p><br>
      <p>I'm not just sorry for the situation. I'm sorry for making you feel like you weren't enough, or that your feelings didn't count. They do.</p><br>
      <p>You deserve better from me, and I really want to do better.</p><br>
      <p style="text-align:right">— me 🤍</p>
    </div>
    <div id="letter-btns" style="display:none">
      <p class="big-text" style="margin: 0.8rem 0 0.2rem">Was that apology at least kinda decent?</p>
      <div class="btn-row">
        <button class="btn btn-yes" onclick="nextPage()">maybe 🤏</button>
        <button class="btn btn-no" onclick="showPopup('popup-bro')">no</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ PAGE 7: MINI GAME ============ -->
<div class="page" id="page-7">
  <div class="progress-dots" id="dots-7"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">🎮</span>
    <span class="doodle-corner doodle-tr">⭐</span>
    <p style="font-family:'Caveat',cursive; font-size:1.3rem; color:var(--text)">catch the floating hearts! 💕</p>
    <p id="game-score-text" style="font-size:0.9rem; color:var(--soft); margin-bottom:0.5rem">Score: <span id="score">0</span> / 10</p>
    <canvas id="game-canvas" width="340" height="200"></canvas>
    <div id="game-result" style="display:none; margin-top:1rem">
      <p class="big-text">Congratulations. You officially spent time on this apology website. 🥺</p>
      <p style="margin-top:0.5rem; color:var(--soft)">So maybe I deserve 0.1 forgiveness?</p>
      <div class="btn-row">
        <button class="btn btn-yes" onclick="nextPage()">maybe 🤏</button>
        <button class="btn btn-no" onclick="showRain()">absolutely not 💀</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ PAGE 8: POLAROIDS ============ -->
<div class="page" id="page-8">
  <div class="progress-dots" id="dots-8"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">📸</span>
    <span class="doodle-corner doodle-tr">🎞️</span>
    <h2>little memories 🤍</h2>
    <div class="polaroid-grid">
      <div class="polaroid" style="--rot:-4deg">
        <span class="pol-emoji">😂</span>
        <p class="pol-caption">us being silly</p>
      </div>
      <div class="polaroid" style="--rot:3deg">
        <span class="pol-emoji">☕</span>
        <p class="pol-caption">random convos that lasted forever</p>
      </div>
      <div class="polaroid" style="--rot:-2deg">
        <span class="pol-emoji">🌙</span>
        <p class="pol-caption">late night energy</p>
      </div>
      <div class="polaroid" style="--rot:5deg">
        <span class="pol-emoji">✨</span>
        <p class="pol-caption">this friendship just hits diff</p>
      </div>
    </div>
    <p class="big-text" style="margin-top:0.8rem">I really don't like when we're not okay.</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="nextPage()">understandable ✓</button>
      <button class="btn btn-no" id="page8-no" onclick="runAwayNo()">no</button>
    </div>
  </div>
</div>

<!-- ============ PAGE 9: FINAL ASK ============ -->
<div class="page" id="page-9">
  <div class="progress-dots" id="dots-9"></div>
  <div class="card">
    <span class="doodle-corner doodle-tl">🌟</span>
    <span class="doodle-corner doodle-tr">💫</span>
    <span class="doodle-corner doodle-bl">✨</span>
    <span class="doodle-corner doodle-br">⭐</span>
    <div style="font-size:2.5rem; margin-bottom:0.8rem">🌙</div>
    <div id="final-text-wrap">
      <p class="big-text" id="ft1" style="opacity:0; transition:opacity 0.7s ease">I know one website can't magically fix everything.</p>
      <p class="big-text" id="ft2" style="opacity:0; transition:opacity 0.7s ease; margin-top:0.5rem">But I wanted you to know…</p>
      <p class="big-text" id="ft3" style="opacity:0; transition:opacity 0.7s ease; margin-top:0.5rem; color:var(--pink)">I genuinely care.</p>
      <p class="big-text" id="ft4" style="opacity:0; transition:opacity 0.7s ease; margin-top:0.5rem">And I genuinely want to make things right.</p>
    </div>
    <h2 id="final-question" style="opacity:0; transition:opacity 0.7s ease; margin-top:1rem">Will you forgive me? 🥺</h2>
    <div class="btn-row" id="final-btns" style="opacity:0; transition:opacity 0.5s ease; pointer-events:none">
      <button class="btn btn-yes" style="font-size:1.5rem; padding:0.9rem 2.5rem" onclick="goFinal()">yes 🤍</button>
      <button class="btn btn-no" id="final-no-btn" onclick="resignNo()">no</button>
    </div>
  </div>
</div>

<!-- ============ FINAL PAGE ============ -->
<div class="page" id="page-final">
  <div class="card" style="max-width:560px">
    <span class="big-emoji" id="final-heart">❤️‍🩹</span>
    <h1 style="font-size:2.6rem; color:var(--pink)">YAYYYY SHE FORGAVE ME 😭🤍</h1>
    <p style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--soft); margin-top:0.5rem">Mission successful.</p>
    <p style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--soft)">Friendship restored.</p>
    <p style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--soft)">Idiot redeemed.</p>
    <div style="width:80%; height:1px; background:var(--blush); margin:1.2rem auto"></div>
    <p class="big-text" style="color:var(--text)">"Thank you for giving me another chance." 🤍</p>
  </div>
</div>

<script>
// ===== STATE =====
let currentPage = 1;
let angerLevel = 5;
let gameScore = 0;
let gameRunning = false;
let gameInterval = null;
let hearts = [];

const statusMessages = [
  "initializing puppy eyes…",
  "loading regret…",
  "deploying sad cat face…",
  "calculating apology strength…",
  "friendship matters detected ✓",
  "emergency forgiveness protocol activated…"
];

// ===== BACKGROUND DOODLES =====
function createBgDoodles() {
  const container = document.getElementById('bg-doodles');
  const emojis = ['🌸', '✨', '💫', '🌷', '⭐', '🌙', '💕', '🍀', '🌈', '🦋', '🌺', '💝'];
  emojis.forEach((emoji, i) => {
    const el = document.createElement('div');
    el.className = 'bg-doodle';
    el.textContent = emoji;
    el.style.left = `${Math.random() * 95}%`;
    el.style.animationDuration = `${8 + Math.random() * 12}s`;
    el.style.animationDelay = `${Math.random() * 8}s`;
    el.style.fontSize = `${1 + Math.random() * 1.5}rem`;
    container.appendChild(el);
  });
}

// ===== STATUS FLOAT =====
const statusQueue = [
  "deploying puppy eyes…",
  "loading regret…",
  "friendship matters detected",
  "apology strength increasing…",
  "emotional vulnerability mode: ON",
  "cuteness protocol engaged…",
  "calculating forgiveness odds…",
  "hope levels: rising 📈"
];
let statusIdx = 0;
function showStatusFloat() {
  const el = document.getElementById('status-float');
  el.textContent = statusQueue[statusIdx % statusQueue.length];
  el.style.opacity = '1';
  statusIdx++;
  setTimeout(() => { el.style.opacity = '0'; }, 3000);
}
setInterval(showStatusFloat, 5000);

// ===== LOADING =====
function runLoading() {
  const bar = document.getElementById('main-loading-bar');
  const statusEl = document.getElementById('loading-status');
  const emojiEl = document.getElementById('loading-emoji');
  const emojis = ['☁️', '🐈', '💔', '😬', '🙏', '💌'];
  let pct = 0, idx = 0;

  const interval = setInterval(() => {
    pct += Math.random() * 18 + 5;
    if (pct > 100) pct = 100;
    bar.style.width = pct + '%';
    statusEl.textContent = statusMessages[Math.min(idx, statusMessages.length - 1)];
    emojiEl.textContent = emojis[Math.min(idx, emojis.length - 1)];
    idx++;

    if (pct >= 100) {
      clearInterval(interval);
      statusEl.textContent = "System ready. 💌";
      setTimeout(() => {
        document.getElementById('enter-btn-wrap').style.display = 'flex';
      }, 600);
    }
  }, 500);
}

// ===== PAGE NAVIGATION =====
function goTo(n) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const pg = document.getElementById('page-' + n);
  if (pg) {
    pg.classList.add('active');
    currentPage = n;
    updateDots(n);
    onPageEnter(n);
  }
}

function nextPage() {
  closeAllPopups();
  goTo(currentPage + 1);
}

function onPageEnter(n) {
  if (n === 2) animateHiPage();
  if (n === 5) { angerLevel = 5; updateAngerMeter(); }
  if (n === 6) { /* envelope waits for click */ }
  if (n === 7) startGame();
  if (n === 9) animateFinalPage();
  if (n === 'final') spawnConfetti();
}

// ===== DOTS =====
function updateDots(page) {
  for (let i = 2; i <= 9; i++) {
    const el = document.getElementById('dots-' + i);
    if (!el) continue;
    el.innerHTML = '';
    for (let j = 2; j <= 9; j++) {
      const dot = document.createElement('span');
      if (j <= page) dot.classList.add('done');
      el.appendChild(dot);
    }
  }
}

// ===== PAGE 2 ANIMATION =====
function animateHiPage() {
  setTimeout(() => {
    document.getElementById('hi-sub').style.opacity = '1';
  }, 800);
  setTimeout(() => {
    const btns = document.getElementById('hi-btns');
    btns.style.opacity = '1';
    btns.style.pointerEvents = 'all';
  }, 1400);
}

// ===== PAGE 4 ERROR =====
function triggerError() {
  document.getElementById('page4-card').classList.add('shake');
  setTimeout(() => document.getElementById('page4-card').classList.remove('shake'), 700);
  showPopup('popup-error');
  const bar = document.getElementById('error-bar');
  let pct = 0;
  const iv = setInterval(() => {
    pct += 12;
    bar.style.width = Math.min(pct, 100) + '%';
    if (pct >= 100) {
      clearInterval(iv);
      document.getElementById('error-loading-text').style.display = 'none';
      document.getElementById('error-result').style.display = 'block';
      document.getElementById('error-btns').style.display = 'flex';
      bar.style.width = '100%';
    }
  }, 250);
}

// ===== PAGE 5 ANGER METER =====
function reduceAnger(level) {
  if (angerLevel > 0) {
    angerLevel = Math.max(0, angerLevel - 1);
    updateAngerMeter();
  }
  if (angerLevel <= 2) {
    setTimeout(() => nextPage(), 800);
  }
}

function updateAngerMeter() {
  const emojis = ['😤', '🔥', '😡'];
  const labels = ['cooling down… 🧊', 'reducing… ❄️', 'still kinda mad 😤', 'very heated 🔥', 'DANGEROUS 🔥🔥', 'CRITICAL LEVEL ☠️'];
  let display = '';
  for (let i = 0; i < angerLevel; i++) display += '🔥';
  for (let i = angerLevel; i < 5; i++) display += '🤍';
  document.getElementById('anger-emojis').textContent = display;
  document.getElementById('anger-label').textContent = labels[Math.min(angerLevel, labels.length - 1)];
}

// ===== PAGE 6 LETTER =====
function openLetter() {
  document.getElementById('envelope-icon').textContent = '📬';
  document.getElementById('envelope-hint').textContent = '';
  document.getElementById('letter-content').style.display = 'block';
  setTimeout(() => {
    document.getElementById('letter-btns').style.display = 'block';
  }, 1000);
}

// ===== PAGE 7 MINI GAME =====
function startGame() {
  const canvas = document.getElementById('game-canvas');
  const ctx = canvas.getContext('2d');
  gameScore = 0;
  hearts = [];
  gameRunning = true;
  document.getElementById('score').textContent = '0';

  canvas.onclick = (e) => {
    if (!gameRunning) return;
    const rect = canvas.getBoundingClientRect();
    const mx = (e.clientX - rect.left) * (canvas.width / rect.width);
    const my = (e.clientY - rect.top) * (canvas.height / rect.height);
    for (let i = hearts.length - 1; i >= 0; i--) {
      const h = hearts[i];
      if (Math.abs(mx - h.x) < 24 && Math.abs(my - h.y) < 24) {
        hearts.splice(i, 1);
        gameScore++;
        document.getElementById('score').textContent = gameScore;
        if (gameScore >= 10) endGame();
        break;
      }
    }
  };

  // Spawn hearts
  const spawnInterval = setInterval(() => {
    if (!gameRunning) { clearInterval(spawnInterval); return; }
    hearts.push({
      x: 20 + Math.random() * (canvas.width - 40),
      y: canvas.height + 20,
      speed: 0.8 + Math.random() * 1.2,
      emoji: ['💕', '💗', '💖', '⭐', '✨', '🌸'][Math.floor(Math.random() * 6)],
      size: 16 + Math.random() * 12
    });
  }, 600);

  // Draw loop
  function draw() {
    if (!gameRunning) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    hearts.forEach(h => {
      h.y -= h.speed;
      ctx.font = h.size + 'px serif';
      ctx.fillText(h.emoji, h.x - h.size / 2, h.y);
    });
    hearts = hearts.filter(h => h.y > -30);
    requestAnimationFrame(draw);
  }
  draw();
}

function endGame() {
  gameRunning = false;
  document.getElementById('game-result').style.display = 'block';
}

// ===== RAIN =====
let rainDrops = [];
function showRain() {
  // Create rain
  for (let i = 0; i < 20; i++) {
    const drop = document.createElement('div');
    drop.className = 'rain-drop';
    drop.style.left = Math.random() * 100 + 'vw';
    drop.style.height = (40 + Math.random() * 60) + 'px';
    drop.style.animationDuration = (0.8 + Math.random() * 0.8) + 's';
    drop.style.animationDelay = Math.random() * 0.5 + 's';
    document.body.appendChild(drop);
    rainDrops.push(drop);
  }
  showPopup('popup-rain');
  const rainText = document.getElementById('rain-text');
  setTimeout(() => {
    rainText.innerHTML = 'okay maybe not crying.<br><span style="font-size:1rem; color:var(--soft)">but definitely overthinking.</span>';
    document.getElementById('rain-btn').style.display = 'flex';
    rainDrops.forEach(d => d.remove());
    rainDrops = [];
  }, 2500);
}

// ===== PAGE 8 RUNNING NO =====
let runningNoActive = false;
function runAwayNo() {
  if (runningNoActive) return;
  document.getElementById('page8-no').style.display = 'none';
  const btn = document.getElementById('running-no');
  btn.style.display = 'block';
  runningNoActive = true;
  moveRunningNo();
  // show tip text
  showTip('why are you bullying the apology button system 😭');
}

function moveRunningNo() {
  if (!runningNoActive) return;
  const btn = document.getElementById('running-no');
  const x = 10 + Math.random() * (window.innerWidth - 120);
  const y = 10 + Math.random() * (window.innerHeight - 60);
  btn.style.left = x + 'px';
  btn.style.top = y + 'px';
  setTimeout(moveRunningNo, 800);
}

function catchRunningNo() {
  // LOL you actually caught it — just proceed
  runningNoActive = false;
  document.getElementById('running-no').style.display = 'none';
  nextPage();
}

// ===== PAGE 9 FINAL =====
function animateFinalPage() {
  // spawn floating stars
  for (let i = 0; i < 15; i++) {
    const star = document.createElement('div');
    star.className = 'floating-star';
    star.textContent = ['⭐','✨','💫','🌟'][Math.floor(Math.random() * 4)];
    star.style.left = Math.random() * 95 + 'vw';
    star.style.top = Math.random() * 90 + 'vh';
    star.style.fontSize = (0.8 + Math.random() * 1.2) + 'rem';
    star.style.animationDuration = (3 + Math.random() * 4) + 's';
    star.style.animationDelay = Math.random() * 2 + 's';
    document.body.appendChild(star);
  }

  const texts = ['ft1','ft2','ft3','ft4'];
  texts.forEach((id, i) => {
    setTimeout(() => {
      document.getElementById(id).style.opacity = '1';
    }, 500 + i * 700);
  });
  setTimeout(() => {
    document.getElementById('final-question').style.opacity = '1';
    const btns = document.getElementById('final-btns');
    btns.style.opacity = '1';
    btns.style.pointerEvents = 'all';
  }, 500 + 4 * 700 + 300);
}

function resignNo() {
  const noBtn = document.getElementById('final-no-btn');
  noBtn.style.transform = 'scale(0)';
  noBtn.style.transition = 'transform 0.3s ease';
  setTimeout(() => {
    noBtn.style.display = 'none';
    showPopup('popup-resigned');
  }, 300);
}

// ===== FINAL PAGE =====
function goFinal() {
  closeAllPopups();
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-final').classList.add('active');
  spawnConfetti();
  animateHeart();
}

function spawnConfetti() {
  const colors = ['#ffb3c6','#e8d5f5','#c8f0e0','#ffd6e0','#d4eeff','#c9b1e8','#fff3b0'];
  for (let i = 0; i < 80; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random() * 100 + 'vw';
    piece.style.top = '-10px';
    piece.style.background = colors[Math.floor(Math.random() * colors.length)];
    piece.style.width = (6 + Math.random() * 8) + 'px';
    piece.style.height = (6 + Math.random() * 8) + 'px';
    piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    piece.style.animationDuration = (2 + Math.random() * 3) + 's';
    piece.style.animationDelay = Math.random() * 1.5 + 's';
    document.body.appendChild(piece);
    setTimeout(() => piece.remove(), 6000);
  }
}

function animateHeart() {
  const h = document.getElementById('final-heart');
  let step = 0;
  const stages = ['💔','💔','❤️','❤️','❤️‍🩹','❤️‍🩹','❤️‍🩹','🤍','❤️'];
  const iv = setInterval(() => {
    h.textContent = stages[step];
    step++;
    if (step >= stages.length) clearInterval(iv);
  }, 400);
}

// ===== POPUP HELPERS =====
function showPopup(id) {
  document.getElementById(id).classList.add('active');
}

function closePopup(id) {
  document.getElementById(id).classList.remove('active');
  // reset error popup
  if (id === 'popup-error') {
    document.getElementById('error-bar').style.width = '0%';
    document.getElementById('error-loading-text').style.display = 'block';
    document.getElementById('error-result').style.display = 'none';
    document.getElementById('error-btns').style.display = 'none';
  }
}

function closeAllPopups() {
  document.querySelectorAll('.popup-overlay').forEach(p => p.classList.remove('active'));
}

// ===== TIPS =====
function showTip(msg) {
  const el = document.getElementById('status-float');
  el.textContent = msg;
  el.style.opacity = '1';
  setTimeout(() => { el.style.opacity = '0'; }, 4000);
}

// ===== INIT =====
createBgDoodles();
runLoading();
</script>
</body>
</html>
